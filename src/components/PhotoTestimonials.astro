---

const photos = [
  // Row 1-2: Hero + 4 small
  { img: "/asset/images/pc-group3.jpg",    span: "col-span-2" },
  { img: "/asset/images/pc-products.jpg",  span: "col-span-2" }, // hero
  { img: "/asset/images/pc-autoparts.jpg", span: "col-span-2" },
  { img: "/asset/images/pc-snack.jpg",     span: "col-span-2" },
  { img: "/asset/images/pc-team.jpg",      span: "col-span-2" },
  { img: "/asset/images/pc-planning.jpg",  span: "col-span-2" },
  { img: "/asset/images/pc-garden.jpg",    span: "" },
  { img: "/asset/images/pc-cafe.jpg",      span: "" },
  { img: "/asset/images/pc-trophy.jpg",    span: "" },
  

  // Row 3: wide session + 2 small
  
  { img: "/asset/images/pc-factory.jpg",   span: "" },
  { img: "/asset/images/pc-1on1.jpg",      span: "" },

  // Row 4: 2 small + wide visit
  
  { img: "/asset/images/pc-strategy.jpg",  span: "" },
  
  // Row 5: wide planning + 2 small
  
  { img: "/asset/images/pc-group2.jpg",    span: "" },
  { img: "/asset/images/pc-amazon.jpg",    span: "" },

  // Row 6: 4 small
  { img: "/asset/images/pc-finance.jpg",   span: "" },
  
  { img: "/asset/images/pc-homemart.jpg",  span: "" },
  { img: "/asset/images/pc-1.jpg",  span: "" },
  { img: "/asset/images/pc-2.jpg",  span: "" },
  

  // Closer: full width
  // { img: "/asset/images/EPC1.jpg",         span: "col-span-2 md:col-span-4 row-span-2", objPos: "object-top" },
];
---

<section class="py-24 bg-black border-t border-yellow-400/20 relative overflow-hidden">

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(250,204,21,0.04)_0%,_transparent_60%)] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">

    <!-- Section Header -->
    <div class="mb-14 max-w-2xl">
      <p class="text-yellow-400 text-sm font-semibold uppercase tracking-[0.2em] mb-4">Private Session Gallery</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-5 leading-tight tracking-tight">
        เบื้องหลัง<span class="text-yellow-400">ทุก Session</span><br class="hidden md:block"/> ที่ธุรกิจเริ่มเปลี่ยน
      </h2>
      <p class="text-base md:text-lg text-gray-400 leading-relaxed">
        ทุก session คือการนั่งวิเคราะห์ธุรกิจของคุณโดยตรง — ไม่ใช่สอนทฤษฎี<br class="hidden md:block"/>
        แต่เจาะลึก วางแผน และหาทางออกร่วมกันแบบตัวต่อตัว
      </p>
    </div>

    <!-- Editorial Photo Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 auto-rows-[220px] md:auto-rows-[240px] gap-3 md:gap-4">
      {photos.map((item) => (
        <figure class={`group relative overflow-hidden rounded-xl bg-neutral-900 border border-white/5 hover:border-yellow-400/40 transition-all duration-500 hover:shadow-[0_0_30px_-8px_rgba(250,204,21,0.25)] cursor-pointer lightbox-trigger ${item.span}`} data-full-src={item.img}>
          <img
            src={item.img}
            class={`w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 `}
            loading="lazy"
            alt="Gallery Img"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-80 pointer-events-none"></div>
          
          <!-- Hover Icon -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none bg-black/40 backdrop-blur-[2px]">
            <svg class="w-10 h-10 text-white shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
          </div>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-gray-600 tracking-wide">
      ภาพจาก Private Consult Session จริง · ปรับตาม Business Case ของแต่ละท่าน
    </p>

  </div>

  <!-- Lightbox Overlay -->
  <div id="image-lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-black/95 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-md">
    <button id="lightbox-close" class="absolute top-6 right-6 lg:top-8 lg:right-10 text-white/50 hover:text-white transition-colors p-2 text-4xl leading-none z-50 focus:outline-none rounded-full hover:bg-white/10 w-12 h-12 flex items-center justify-center">
      &times;
    </button>
    <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] object-contain px-4 sm:px-8 scale-95 transition-transform duration-300 ease-out" alt="Expanded view" />
  </div>
</section>

<script>
  function setupLightbox() {
    const triggers = document.querySelectorAll('.lightbox-trigger');
    const lightbox = document.getElementById('image-lightbox') as HTMLElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

    if (!lightbox || !lightboxImg || !closeBtn) return;

    function openLightbox(src: string) {
      lightboxImg.src = src;
      lightbox.classList.remove('opacity-0', 'pointer-events-none');
      lightbox.classList.add('opacity-100');
      // Adding a small delay for animation
      setTimeout(() => {
        lightboxImg.classList.remove('scale-95');
        lightboxImg.classList.add('scale-100');
      }, 50);
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('opacity-100');
      lightbox.classList.add('opacity-0', 'pointer-events-none');
      lightboxImg.classList.remove('scale-100');
      lightboxImg.classList.add('scale-95');
      document.body.style.overflow = '';
      
      // Delay resetting the image source to prevent visual artifacts
      setTimeout(() => {
        if(lightbox.classList.contains('opacity-0')) {
           lightboxImg.src = '';
        }
      }, 300);
    }

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-full-src');
        if (src) openLightbox(src);
      });
    });

    closeBtn.addEventListener('click', closeLightbox);
    
    // Close on background click
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightbox();
      }
    });
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('opacity-100')) {
        closeLightbox();
      }
    });
  }

  // Run on initial load and view transitions
  setupLightbox();
  document.addEventListener('astro:page-load', setupLightbox);
</script>
