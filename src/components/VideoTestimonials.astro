---
<section class="py-24 bg-neutral-950 border-t border-red-500/40 relative overflow-hidden">
  <!-- Subtle lighting detail -->
  <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-red-600/10 rounded-full blur-[120px] pointer-events-none mix-blend-screen -translate-y-1/2"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 tracking-tight">ทำไมเจ้าของธุรกิจถึงประทับใจ <br class="hidden"/><span class="text-yellow-400">พี่วิน</span></h2>
      <p class="text-lg text-gray-400">
        ฟังเสียงวิจารณ์จากประสบการณ์ตรงของลูกค้า SME ที่ใช้เข้าร่วมเป็นที่ปรึกษากับเรา
      </p>
    </div>

    <!-- Responsive Video Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {videos.map((vid) => (
        <div class="flex flex-col bg-black rounded-3xl border border-white/5 overflow-hidden shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5)] transition-transform duration-500 hover:-translate-y-2 hover:border-yellow-400/30 hover:shadow-[0_20px_40px_-15px_rgba(250,204,21,0.15)]">
          <!-- Video Embed Wrapper -->
          <div class="relative w-full aspect-video bg-neutral-900">
            {/* Note: In production you would use a highly optimized lite-youtube-embed or a standard iframe */}
            <iframe 
              class="absolute inset-0 w-full h-full"
              src={`https://www.youtube-nocookie.com/embed/${vid.videoId}?rel=0&modestbranding=1`} 
              title="YouTube video player" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          
          <!-- Content padding and quote -->
          <div class="p-8 flex flex-col flex-grow relative">
            <!-- decorative quote icon -->
            {/* <svg class="w-8 h-8 text-red-500/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg> */}
            
            {/* <p class="text-gray-300 text-base md:text-lg italic leading-relaxed mb-8 flex-grow">
              "{vid.quote}"
            </p>
            
            <div class="border-t border-white/10 pt-6 mt-auto">
              <h4 class="font-bold text-white text-lg">{vid.name}</h4>
              <p class="text-sm text-yellow-500 mt-1">{vid.business}</p>
            </div> */}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
