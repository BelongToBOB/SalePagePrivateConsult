---
// SeminarGallery.astro
const images = [
  "https://images.unsplash.com/photo-1540575467063-178a50c2df87?q=80&w=2070&auto=format&fit=crop", // Main large image
  "https://images.unsplash.com/photo-1556761175-129418cb210d?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1515169067868-5387ec356754?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1558403194-611308249627?q=80&w=800&auto=format&fit=crop"
];
---
<section class="py-20 bg-black border-t border-red-500/40 relative overflow-hidden">
  
  {/* Decorative Ambient Glow */}
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-red-900/10 blur-[120px] rounded-full mix-blend-screen pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    
    <div class="text-center md:text-left mb-12 max-w-3xl">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight leading-tight text-balance">
        บรรยากาศการสัมมนาและ<br class="hidden sm:block"/>การให้คำปรึกษาธุรกิจ
      </h2>
      <p class="text-lg md:text-xl text-gray-400 font-light leading-relaxed text-balance">
        ทีม Win WinWealth Creation ให้คำแนะนำกับผู้ประกอบการ SME จากหลากหลายอุตสาหกรรม
      </p>
    </div>

    {/* Layout Group */}
    <div class="flex flex-col gap-4 md:gap-6">
      
      {/* 1. Large Hero Image */}
      <div class="group relative w-full h-[50vh] md:h-[65vh] overflow-hidden rounded-2xl md:rounded-3xl shadow-2xl bg-neutral-950 border border-white/10 ring-1 ring-yellow-400/10">
        <img 
          src={images[0]} 
          alt="งานสัมมนาขนาดใหญ่ Win WinWealth Creation" 
          class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
          loading="lazy"
        />
        {/* Subtle overlay for contrast */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-80 mix-blend-multiply transition-opacity duration-500 group-hover:opacity-60"></div>
      </div>

      {/* 2. Smaller Image Grid */}
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {images.slice(1).map((src) => (
          <div class="group relative aspect-square overflow-hidden rounded-xl md:rounded-2xl bg-neutral-900 border border-white/5 shadow-lg">
            <img 
              src={src} 
              alt="ภาพบรรยากาศการให้คำปรึกษา" 
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 grayscale-[10%] group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-yellow-900/20 mix-blend-overlay opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>
