---
import Layout from '../layouts/Layout.astro';
import HeroKV from '../components/HeroKV.astro';
import PhotoTestimonials from '../components/PhotoTestimonials.astro';
import VideoTestimonials from '../components/VideoTestimonials.astro';
import SeminarGallery from '../components/SeminarGallery.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<Layout title="Win WinWealth Creation | ที่ปรึกษาการเงินและสินเชื่อ SME" description="ที่ปรึกษาแบบมืออาชีพ ช่วยธุรกิจ SME วางโครงสร้างการเงินและยื่นกู้สินเชื่อให้ผ่านง่ายขึ้น">
  <main class="bg-black min-h-screen text-gray-50 flex flex-col selection:bg-yellow-400/30">
    <HeroKV />
    <PhotoTestimonials />
    <VideoTestimonials />
    <SeminarGallery />
    <ContactCTA />
  </main>
  
  <footer class="bg-black py-12 border-t border-red-500/20 text-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} Win WinWealth Creation. สงวนลิขสิทธิ์ทั้งหมด
      </p>
    </div>
  </footer>
</Layout>
